---
import { siteConfig } from "../../../site.config";
---

<nav class="topbar">
  <a href="/">{siteConfig.name}</a>
  <span class="topbar-sep">&middot;</span>
  <a href="/walks">walks</a>
  <span class="topbar-sep">&middot;</span>
  <a href="/curated">curated</a>
  <span class="topbar-sep">&middot;</span>
  <a href="/nexus">nexus</a>
  <span class="topbar-sep">&middot;</span>
  <a href="/people">people</a>
  <span class="topbar-sep">&middot;</span>
  <a href="/admin" id="authLink">log in</a>
  <a href="/admin" id="writeLink" class="write-link" style="display:none;">
    <span class="topbar-sep">&middot;</span>
    write
  </a>
</nav>

<style>
  .topbar {
    max-width: 960px;
    margin: 0 auto;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-rule);
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-meta);
  }

  .topbar a {
    color: var(--color-text);
  }

  .topbar-sep {
    margin: 0 0.25rem;
  }

  .write-link {
    display: none;
  }
</style>

<script>
  const authLink = document.getElementById("authLink") as HTMLAnchorElement;
  const writeLink = document.getElementById("writeLink") as HTMLAnchorElement;

  try {
    const stored = localStorage.getItem("netlify-cms-user");
    if (stored) {
      const user = JSON.parse(stored);
      if (user.token) {
        // Logged in: show handle and write link
        if (user.name) {
          authLink.textContent = user.name;
          authLink.href = `/people/${user.name}`;
        }
        writeLink.style.display = "inline";
      }
    }
  } catch {
    // Not logged in — defaults are fine
  }
</script>
