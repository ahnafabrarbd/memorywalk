---
import { siteConfig } from "../../../site.config";
const base = import.meta.env.BASE_URL;
---

<nav class="topbar">
  <a href={`${base}`} class="topbar-brand">{siteConfig.name}</a>
  <div class="topbar-links">
    <a href={`${base}walks`}>walks</a>
    <a href={`${base}nexus`}>nexus</a>
    <a href={`${base}about`}>about</a>
  </div>
</nav>

<style>
  .topbar {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 0;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    position: relative;
    z-index: 10;
  }

  .topbar-brand {
    font-family: var(--font-display);
    font-size: var(--size-nav);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text);
  }

  .topbar-brand:hover {
    color: var(--color-accent-red);
  }

  .topbar-links {
    display: flex;
    gap: 1.5rem;
  }

  .topbar-links a {
    font-family: var(--font-display);
    font-size: var(--size-label);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-dim);
  }

  .topbar-links a:hover {
    color: var(--color-accent-red);
  }

  @media (max-width: 480px) {
    .topbar {
      padding: 1rem 0;
    }

    .topbar-links {
      gap: 1rem;
    }
  }
</style>
