---
import "../components/shared/tokens.css";
import { siteConfig } from "../../site.config";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {siteConfig.name}</title>
    <style>
      body {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem 1rem;
      }

      .reader-content {
        width: 100%;
        max-width: 640px;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .reader-content :global(.page-image) {
        max-width: 640px;
        max-height: 480px;
        width: 100%;
        height: auto;
      }

      .reader-content :global(.page-body) {
        max-width: var(--measure);
        width: 100%;
        margin-top: 2rem;
        font-size: var(--size-base);
        line-height: var(--leading);
      }

      .reader-content :global(.page-nav) {
        width: 100%;
        max-width: var(--measure);
        margin-top: 3rem;
        font-family: var(--font-mono);
        font-size: var(--size-sm);
        color: var(--color-meta);
      }

      @media (max-width: 480px) {
        body {
          padding: 1.5rem 1rem;
        }

        .reader-content :global(.page-body) {
          margin-top: 1.5rem;
        }

        .reader-content :global(.page-nav) {
          margin-top: 2rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="reader-content">
      <slot />
    </div>
  </body>
</html>
