---
import "../components/shared/tokens.css";
import ShaderBackground from "../components/shared/ShaderBackground.astro";
import TopBar from "../components/list/TopBar.astro";
import { siteConfig } from "../../site.config";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {siteConfig.name}</title>
    <style>
      body {
        padding: 0 1rem;
      }

      .list-content {
        max-width: 1200px;
        margin: 0 auto;
        padding-bottom: 4rem;
        position: relative;
        z-index: 1;
      }
    </style>
  </head>
  <body>
    <ShaderBackground />
    <TopBar />
    <div class="list-content">
      <slot />
    </div>
  </body>
</html>
