---
import List from "../../layouts/List.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const walks = await getCollection("walks");
const sorted = walks.sort(
  (a, b) => b.data.started_at.getTime() - a.data.started_at.getTime(),
);

const allTags = [...new Set(walks.flatMap((w) => w.data.tags))].sort();

const walkData = sorted.map((w) => {
  const parts = w.id.split("/");
  return {
    slug: parts[1],
    title: w.data.title,
    date: w.data.started_at.toISOString().slice(0, 10),
    dateMs: w.data.started_at.getTime(),
    tags: w.data.tags,
    structure: w.data.structure,
    summary: w.data.summary,
  };
});
---

<List title="walks">
  <div class="walks-page">
    <h1 class="page-title">walks</h1>

    <div class="controls">
      <select id="sortSelect">
        <option value="date-desc">newest</option>
        <option value="date-asc">oldest</option>
        <option value="title">title</option>
      </select>

      {allTags.length > 0 && (
        <select id="tagSelect">
          <option value="">all tags</option>
          {allTags.map((t) => (
            <option value={t}>#{t}</option>
          ))}
        </select>
      )}
    </div>

    <ul class="walk-list" id="walkList">
      {walkData.map((w) => (
        <li
          class="walk-row"
          data-title={w.title}
          data-date={w.dateMs}
          data-tags={w.tags.join(",")}
          data-structure={w.structure}
        >
          <a href={`${base}walk/${w.slug}`} class="walk-title">{w.title}</a>
          <span class="walk-meta">
            {w.date}
            {w.tags.length > 0 && (
              <span class="walk-tags">
                {w.tags.map((t) => `#${t}`).join(" ")}
              </span>
            )}
          </span>
          <span class="walk-summary">{w.summary}</span>
        </li>
      ))}
    </ul>

    {walkData.length === 0 && <p class="empty">no walks yet</p>}
  </div>
</List>

<style>
  .walks-page {
    padding-top: 2rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--size-title-walk);
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .controls {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .controls select {
    background: rgba(0, 0, 0, 0.5);
    color: var(--color-text);
    border: 1px solid var(--color-rule);
    font-family: var(--font-display);
    font-size: var(--size-label);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 0.8rem;
    cursor: pointer;
  }

  .walk-list {
    list-style: none;
  }

  .walk-row {
    padding: clamp(0.75rem, 1.5vh, 1.25rem) 0;
    border-bottom: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .walk-row:first-child {
    border-top: 1px solid var(--color-rule);
  }

  .walk-title {
    font-family: var(--font-display);
    font-size: var(--size-index-title);
    font-weight: 600;
  }

  .walk-meta {
    font-family: var(--font-display);
    font-size: var(--size-label);
    font-weight: 500;
    color: var(--color-dim);
  }

  .walk-tags {
    color: var(--color-accent-blue);
    margin-left: 0.5rem;
  }

  .walk-summary {
    font-size: var(--size-label);
    color: var(--color-dim);
  }

  .empty {
    font-size: var(--size-body);
    color: var(--color-dim);
  }
</style>

<script>
  const list = document.getElementById("walkList")!;
  const sortSelect = document.getElementById("sortSelect") as HTMLSelectElement;
  const tagSelect = document.getElementById("tagSelect") as HTMLSelectElement | null;

  function apply() {
    const rows = Array.from(list.querySelectorAll(".walk-row")) as HTMLElement[];
    const sort = sortSelect.value;
    const tag = tagSelect?.value ?? "";

    rows.forEach((row) => {
      const tags = row.dataset.tags ?? "";
      row.style.display = !tag || tags.split(",").includes(tag) ? "" : "none";
    });

    const visible = rows.filter((r) => r.style.display !== "none");
    visible.sort((a, b) => {
      if (sort === "date-asc") return Number(a.dataset.date) - Number(b.dataset.date);
      if (sort === "title") return (a.dataset.title ?? "").localeCompare(b.dataset.title ?? "");
      return Number(b.dataset.date) - Number(a.dataset.date);
    });
    visible.forEach((r) => list.appendChild(r));
  }

  sortSelect.addEventListener("change", apply);
  tagSelect?.addEventListener("change", apply);
</script>
