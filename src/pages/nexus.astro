---
import List from "../layouts/List.astro";
---

<List title="nexus">
  <div class="nexus-page">
    <div class="nexus-controls">
      <span class="control-label">nexus</span>
      <span class="control-sep">&middot;</span>
      <label class="filter-toggle">
        <input type="checkbox" id="filterGeo" checked />
        geographic
      </label>
    </div>
    <div id="nexusMap" class="nexus-map"></div>
  </div>
</List>

<style>
  .nexus-page {
    padding-top: 1rem;
  }

  .nexus-controls {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-meta);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .control-label {
    color: var(--color-meta);
  }

  .control-sep {
    color: var(--color-rule);
  }

  .filter-toggle {
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .filter-toggle input {
    cursor: pointer;
  }

  .nexus-map {
    width: 100%;
    height: calc(100vh - 8rem);
    min-height: 400px;
    border: 1px solid var(--color-rule);
  }
</style>

<script>
  import L from "leaflet";
  import "leaflet/dist/leaflet.css";

  interface WalkIndexEntry {
    author: string;
    slug: string;
    title: string;
    pages: {
      id: string;
      coords: [number, number] | null;
      captured_at: string;
    }[];
  }

  interface GeoCollision {
    type: string;
    a: { walkAuthor: string; walkSlug: string; walkTitle: string; pageId: string };
    b: { walkAuthor: string; walkSlug: string; walkTitle: string; pageId: string };
    distance_m: number;
  }

  interface CollisionsData {
    geographic: GeoCollision[];
  }

  const map = L.map("nexusMap", {
    zoomControl: false,
    attributionControl: false,
  }).setView([37.775, -122.419], 15);

  L.tileLayer(
    "https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png",
    {
      maxZoom: 19,
    },
  ).addTo(map);

  // Add small attribution
  L.control.attribution({ prefix: false, position: "bottomright" })
    .addAttribution('&copy; <a href="https://carto.com/">CARTO</a> &copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>')
    .addTo(map);

  const dotOptions: L.CircleMarkerOptions = {
    radius: 4,
    fillColor: "#fff",
    fillOpacity: 0.5,
    stroke: false,
  };

  const lineOptions: L.PolylineOptions = {
    color: "#fff",
    opacity: 0.3,
    weight: 1,
  };

  const dots: L.CircleMarker[] = [];
  const collisionLines: L.Polyline[] = [];

  // Fetch data
  Promise.all([
    fetch("/walks-index.json").then((r) => r.json()) as Promise<WalkIndexEntry[]>,
    fetch("/collisions.json").then((r) => r.json()) as Promise<CollisionsData>,
  ]).then(([walks, collisions]) => {
    const coordMap = new Map<string, [number, number]>();
    const bounds: [number, number][] = [];

    // Plot dots
    for (const walk of walks) {
      for (const page of walk.pages) {
        if (!page.coords) continue;
        const key = `${walk.author}/${walk.slug}/${page.id}`;
        coordMap.set(key, page.coords);

        const dot = L.circleMarker(page.coords, dotOptions)
          .bindPopup(
            `<span style="font-family:monospace;font-size:12px;color:#fff;background:#000;padding:2px 4px;">${walk.title} — ${page.id}</span>`,
            { className: "nexus-popup" },
          )
          .on("click", () => {
            window.open(`/walk/${walk.author}/${walk.slug}/page/${page.id}`, "_blank");
          })
          .addTo(map);

        dots.push(dot);
        bounds.push(page.coords);
      }
    }

    // Draw collision lines
    for (const c of collisions.geographic) {
      const aKey = `${c.a.walkAuthor}/${c.a.walkSlug}/${c.a.pageId}`;
      const bKey = `${c.b.walkAuthor}/${c.b.walkSlug}/${c.b.pageId}`;
      const aCoords = coordMap.get(aKey);
      const bCoords = coordMap.get(bKey);
      if (!aCoords || !bCoords) continue;

      const line = L.polyline([aCoords, bCoords], lineOptions)
        .bindTooltip(
          `${c.a.walkTitle} — ${c.b.walkTitle} (${c.distance_m}m)`,
          {
            className: "nexus-tooltip",
            sticky: true,
          },
        )
        .addTo(map);

      collisionLines.push(line);
    }

    // Fit bounds if we have dots
    if (bounds.length > 0) {
      map.fitBounds(L.latLngBounds(bounds), { padding: [40, 40] });
    }
  });

  // Filter toggle
  const filterGeo = document.getElementById("filterGeo") as HTMLInputElement;
  filterGeo.addEventListener("change", () => {
    collisionLines.forEach((line) => {
      if (filterGeo.checked) {
        line.addTo(map);
      } else {
        line.remove();
      }
    });
  });
</script>

<style is:global>
  .nexus-popup .leaflet-popup-content-wrapper {
    background: #000;
    border: 1px solid #222;
    border-radius: 0;
    box-shadow: none;
  }

  .nexus-popup .leaflet-popup-tip {
    background: #000;
    border: 1px solid #222;
  }

  .nexus-tooltip {
    background: #000 !important;
    border: 1px solid #222 !important;
    border-radius: 0 !important;
    color: #888 !important;
    font-family: monospace !important;
    font-size: 0.75rem !important;
    box-shadow: none !important;
  }

  .nexus-tooltip::before {
    display: none !important;
  }

  .leaflet-container {
    background: #000 !important;
  }
</style>
