---
import List from "../layouts/List.astro";
---

<List title="nexus">
  <div class="nexus-page">
    <h1 class="page-title">nexus</h1>
    <p class="stub-note">map pending — will be rebuilt from Weather Journal</p>
  </div>
</List>

<style>
  .nexus-page {
    padding-top: 2rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--size-title-walk);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .stub-note {
    font-size: var(--size-body);
    color: var(--color-dim);
  }
</style>
