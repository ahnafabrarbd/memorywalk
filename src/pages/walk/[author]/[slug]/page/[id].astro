---
import { getCollection, render } from "astro:content";
import Reader from "../../../../../layouts/Reader.astro";
import PageNav from "../../../../../components/reader/PageNav.astro";
import MiniMap from "../../../../../components/reader/MiniMap.astro";
import { siteConfig } from "../../../../../../site.config";

export async function getStaticPaths() {
  const allPages = await getCollection("pages");
  const walks = await getCollection("walks");

  const paths = [];

  for (const page of allPages) {
    const parts = page.id.split("/");
    const author = parts[0];
    const slug = parts[1];
    const pageId = parts[2];

    const prefix = `${author}/${slug}/`;
    const siblings = allPages
      .filter((p) => p.id.startsWith(prefix))
      .sort((a, b) => a.id.localeCompare(b.id));

    const walk = walks.find((w) => {
      const wParts = w.id.split("/");
      return wParts[0] === author && wParts[1] === slug;
    });

    paths.push({
      params: { author, slug, id: pageId },
      props: {
        page,
        walk,
        siblings,
        walkAuthor: author,
        walkSlug: slug,
      },
    });
  }

  return paths;
}

const { page, walk, siblings, walkAuthor, walkSlug } = Astro.props;
const { id: pageId } = Astro.params;

const structure = walk?.data.structure ?? "linear";
const currentIndex = siblings.findIndex((s) => s.id.endsWith(`/${pageId}`));
const total = siblings.length;

// Linear navigation
const prevPage = currentIndex > 0 ? siblings[currentIndex - 1] : null;
const nextPage = currentIndex < total - 1 ? siblings[currentIndex + 1] : null;
const prevUrl = prevPage
  ? `/walk/${walkAuthor}/${walkSlug}/page/${prevPage.id.split("/").pop()}`
  : null;
const nextUrl = nextPage
  ? `/walk/${walkAuthor}/${walkSlug}/page/${nextPage.id.split("/").pop()}`
  : null;

// Branching links
const branchLinks = (page.data.links ?? []).map((linkId: string) => ({
  id: linkId,
  url: `/walk/${walkAuthor}/${walkSlug}/page/${linkId}`,
}));

// Geo-anchored: mini-map data
const geoPages = siblings
  .filter((s) => s.data.coords)
  .map((s) => ({
    id: s.data.id,
    coords: s.data.coords as [number, number],
    url: `/walk/${walkAuthor}/${walkSlug}/page/${s.id.split("/").pop()}`,
  }));

const { Content } = await render(page);

// Enforce body word count constraint (§11: <=400 words)
if (page.body) {
  const wordCount = page.body.trim().split(/\s+/).filter(Boolean).length;
  if (wordCount > 400) {
    throw new Error(
      `Page ${page.id} has ${wordCount} words (max 400). Reduce the body text.`,
    );
  }
}

const localImagePath = `/content-images/${walkAuthor}/${walkSlug}/${page.data.image}`;
const ipfsEnabled = siteConfig.ipfs.enabled && page.data.image_cid;
const imagePath = ipfsEnabled
  ? `${siteConfig.ipfs.gateway}/${page.data.image_cid}`
  : localImagePath;
const walkTitle = walk?.data.title ?? "untitled walk";

// Determine if this is the final page (for "write your own" link)
const isLastPage =
  (structure === "linear" || structure === "geo-anchored")
    ? !page.data.next
    : (structure === "branching" ? !page.data.links || page.data.links.length === 0 : false);
---

<Reader title={`${walkTitle} — ${page.data.id}`}>
  {structure === "geo-anchored" && geoPages.length > 0 && (
    <MiniMap pages={geoPages} currentPageId={page.data.id} />
  )}

  {ipfsEnabled ? (
    <img
      class="page-image"
      src={imagePath}
      alt=""
      onerror={`this.onerror=null;this.src='${localImagePath}';`}
    />
  ) : (
    <img class="page-image" src={imagePath} alt="" />
  )}

  <div class="page-body">
    <Content />

    {structure === "branching" && branchLinks.length > 0 && (
      <div class="branch-links">
        {branchLinks.map((link: { id: string; url: string }) => (
          <a href={link.url} class="branch-link" data-page-id={link.id}>
            {link.id}
          </a>
        ))}
      </div>
    )}
  </div>

  {structure === "linear" && (
    <PageNav
      current={currentIndex + 1}
      total={total}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
    />
  )}

  {structure === "geo-anchored" && (
    <PageNav
      current={currentIndex + 1}
      total={total}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
    />
  )}

  {structure === "branching" && (
    <div class="page-nav">
      <span class="branch-meta">{page.data.id}</span>
    </div>
  )}

  {isLastPage && (
    <div class="write-own">
      <a href="/admin">write your own</a>
    </div>
  )}
</Reader>

<style>
  .branch-links {
    margin-top: 1.5rem;
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: var(--size-sm);
  }

  .branch-link {
    color: var(--color-text);
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 0.125rem;
  }

  .branch-link:hover {
    text-decoration: none;
    border-color: var(--color-text);
  }

  .branch-link.visited {
    color: var(--color-meta);
  }

  .write-own {
    width: 100%;
    max-width: var(--measure);
    margin-top: 3rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: var(--size-sm);
  }

  .write-own a {
    color: var(--color-meta);
  }

  .write-own a:hover {
    color: var(--color-text);
  }

  .branch-meta {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-meta);
  }
</style>

<script>
  // Branching: track visited pages in sessionStorage
  const walkPath = window.location.pathname.split("/page/")[0];
  const storageKey = `visited:${walkPath}`;
  const visited = new Set(JSON.parse(sessionStorage.getItem(storageKey) || "[]"));

  // Mark current page as visited
  const currentPageId = window.location.pathname.split("/page/")[1]?.replace(/\/$/, "");
  if (currentPageId) {
    visited.add(currentPageId);
    sessionStorage.setItem(storageKey, JSON.stringify([...visited]));
  }

  // Style visited branch links
  document.querySelectorAll<HTMLAnchorElement>(".branch-link").forEach((link) => {
    const pageId = link.dataset.pageId;
    if (pageId && visited.has(pageId)) {
      link.classList.add("visited");
    }
  });
</script>
