---
import List from "../../layouts/List.astro";
import { getCollection } from "astro:content";

// Dev-mode only: this page won't be useful in production
// but we keep it buildable. The actual editing requires dev server.

const base = import.meta.env.BASE_URL;
const walks = await getCollection("walks");
const walkData = walks
  .sort((a, b) => b.data.started_at.getTime() - a.data.started_at.getTime())
  .map((w) => {
    const parts = w.id.split("/");
    return { slug: parts[1], title: w.data.title };
  });
---

<List title="write">
  <div class="write-page">
    <h1 class="page-title">write</h1>

    <a href={`${base}write/new`} class="new-walk-btn">+ new walk</a>

    {walkData.length > 0 && (
      <div class="existing">
        <h2 class="section-label">existing walks</h2>
        <ul class="walk-list">
          {walkData.map((w) => (
            <li class="walk-row">
              <a href={`${base}write/${w.slug}`} class="walk-title">{w.title}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</List>

<style>
  .write-page {
    padding-top: 2rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--size-title-walk);
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .new-walk-btn {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--size-index-title);
    font-weight: 700;
    color: var(--color-accent-green);
    border: 1px solid var(--color-accent-green);
    padding: 0.75rem 1.5rem;
    transition: all 150ms;
  }

  .new-walk-btn:hover {
    color: #000;
    background: var(--color-accent-green);
    text-decoration: none;
  }

  .existing {
    margin-top: 3rem;
  }

  .section-label {
    font-family: var(--font-display);
    font-size: var(--size-label);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-green);
    margin-bottom: 1rem;
  }

  .walk-list {
    list-style: none;
  }

  .walk-row {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-rule);
  }

  .walk-row:first-child {
    border-top: 1px solid var(--color-rule);
  }

  .walk-title {
    font-family: var(--font-display);
    font-size: var(--size-index-title);
    font-weight: 600;
  }
</style>
