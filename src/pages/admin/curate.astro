---
import List from "../../layouts/List.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../site.config";

const walks = await getCollection("walks");
const published = walks.sort(
  (a, b) => b.data.started_at.getTime() - a.data.started_at.getTime(),
);

const walkData = published.map((w) => {
  const parts = w.id.split("/");
  return {
    author: parts[0],
    slug: parts[1],
    title: w.data.title,
    date: w.data.started_at.toISOString().slice(0, 10),
    curated: w.data.curated,
    filePath: `content/walks/${parts[0]}/${parts[1]}/walk.md`,
  };
});
---

<List title="curate">
  <div class="curate-page">
    <h1 class="page-heading">curate</h1>
    <p class="note" id="authStatus">checking access...</p>

    <div id="curateContent" style="display:none;">
      <ul class="walk-list">
        {walkData.map((w) => (
          <li
            class="walk-row"
            data-author={w.author}
            data-slug={w.slug}
            data-curated={String(w.curated)}
            data-filepath={w.filePath}
          >
            <div class="walk-info">
              <a href={`/walk/${w.author}/${w.slug}`}>{w.title}</a>
              <span class="walk-meta">
                {w.author} &middot; {w.date}
                {w.curated && <span class="curated-badge">curated</span>}
              </span>
            </div>
            <button class="curate-btn" data-action={w.curated ? "uncurate" : "curate"}>
              {w.curated ? "uncurate" : "curate"}
            </button>
          </li>
        ))}
      </ul>
    </div>
  </div>
</List>

<style>
  .curate-page {
    padding-top: 2rem;
  }

  .page-heading {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    font-weight: normal;
    color: var(--color-meta);
    margin-bottom: 0.5rem;
  }

  .note {
    font-size: var(--size-sm);
    color: var(--color-meta);
    margin-bottom: 1.5rem;
  }

  .walk-list {
    list-style: none;
  }

  .walk-row {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-rule);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .walk-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .walk-info a {
    font-size: var(--size-base);
  }

  .walk-meta {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-meta);
  }

  .curated-badge {
    margin-left: 0.5rem;
    color: var(--color-text);
  }

  .curate-btn {
    background: none;
    border: 1px solid var(--color-rule);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    padding: 0.25rem 0.75rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .curate-btn:hover {
    border-color: var(--color-text);
  }

  .curate-btn:disabled {
    color: var(--color-meta);
    cursor: not-allowed;
  }
</style>

<script define:vars={{ repoUrl: siteConfig.repoUrl, walkDataJSON: JSON.stringify(walkData) }}>
  const curators = [];
  const authStatus = document.getElementById("authStatus");
  const curateContent = document.getElementById("curateContent");

  async function checkAccess() {
    // Get token from Decap's localStorage
    const token = localStorage.getItem("netlify-cms-user")
      ? JSON.parse(localStorage.getItem("netlify-cms-user")).token
      : null;

    if (!token) {
      authStatus.textContent = "log in via /admin first";
      return;
    }

    // Fetch GitHub user
    try {
      const res = await fetch("https://api.github.com/user", {
        headers: { Authorization: `token ${token}` },
      });
      if (!res.ok) {
        authStatus.textContent = "invalid token. log in via /admin again.";
        return;
      }
      const user = await res.json();

      // Fetch curators list
      const curatorsRes = await fetch("/curators.json");
      const curatorsList = await curatorsRes.json();

      if (!curatorsList.includes(user.login)) {
        authStatus.textContent = "access restricted";
        return;
      }

      authStatus.textContent = `logged in as ${user.login}`;
      curateContent.style.display = "block";
      setupButtons(token);
    } catch (err) {
      authStatus.textContent = "error checking access";
    }
  }

  function setupButtons(token) {
    document.querySelectorAll(".curate-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const row = btn.closest(".walk-row");
        const filepath = row.dataset.filepath;
        const isCurated = row.dataset.curated === "true";
        const newCurated = !isCurated;

        btn.disabled = true;
        btn.textContent = "updating...";

        try {
          // Parse repo from repoUrl
          const repoMatch = repoUrl.match(/github\.com\/([^/]+\/[^/]+)/);
          if (!repoMatch) throw new Error("Invalid repo URL");
          const repo = repoMatch[1];

          // Get current file content
          const fileRes = await fetch(
            `https://api.github.com/repos/${repo}/contents/${filepath}`,
            { headers: { Authorization: `token ${token}` } }
          );
          const fileData = await fileRes.json();
          const content = atob(fileData.content);

          // Update curated field in frontmatter
          let updated;
          if (newCurated) {
            updated = content
              .replace(/^curated: false$/m, "curated: true")
              .replace(/^curated_at: null$/m, `curated_at: ${new Date().toISOString()}`);
          } else {
            updated = content
              .replace(/^curated: true$/m, "curated: false")
              .replace(/^curated_at: .+$/m, "curated_at: null");
          }

          // Commit the update
          await fetch(
            `https://api.github.com/repos/${repo}/contents/${filepath}`,
            {
              method: "PUT",
              headers: {
                Authorization: `token ${token}`,
                "Content-Type": "application/json",
              },
              body: JSON.stringify({
                message: `${newCurated ? "curate" : "uncurate"}: ${row.querySelector("a").textContent}`,
                content: btoa(updated),
                sha: fileData.sha,
              }),
            }
          );

          row.dataset.curated = String(newCurated);
          btn.dataset.action = newCurated ? "uncurate" : "curate";
          btn.textContent = newCurated ? "uncurate" : "curate";

          const badge = row.querySelector(".curated-badge");
          if (newCurated && !badge) {
            const meta = row.querySelector(".walk-meta");
            const span = document.createElement("span");
            span.className = "curated-badge";
            span.textContent = "curated";
            meta.appendChild(span);
          } else if (!newCurated && badge) {
            badge.remove();
          }
        } catch (err) {
          console.error("Curate failed:", err);
          btn.textContent = "error";
        } finally {
          btn.disabled = false;
        }
      });
    });
  }

  checkAccess();
</script>
