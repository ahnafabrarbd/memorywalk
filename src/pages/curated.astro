---
import List from "../layouts/List.astro";
import { getCollection } from "astro:content";

const walks = await getCollection("walks");
const curated = walks
  .filter((w) => w.data.curated)
  .sort((a, b) => {
    const aTime = a.data.curated_at?.getTime() ?? 0;
    const bTime = b.data.curated_at?.getTime() ?? 0;
    return bTime - aTime;
  });
---

<List title="curated">
  <div class="curated-page">
    <h1 class="page-heading">curated</h1>
    <p class="curated-note">selected by editors</p>
    {curated.length > 0 ? (
      <ul class="walk-list">
        {curated.map((w) => {
          const parts = w.id.split("/");
          return (
            <li class="walk-row">
              <a href={`/walk/${parts[0]}/${parts[1]}`}>{w.data.title}</a>
              <span class="walk-meta">
                {w.data.author} &middot; {w.data.started_at.toISOString().slice(0, 10)}
              </span>
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="empty">none yet</p>
    )}
  </div>
</List>

<style>
  .curated-page {
    padding-top: 2rem;
  }

  .page-heading {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    font-weight: normal;
    color: var(--color-meta);
    margin-bottom: 0.25rem;
  }

  .curated-note {
    font-size: var(--size-sm);
    color: var(--color-meta);
    margin-bottom: 1.5rem;
  }

  .walk-list {
    list-style: none;
  }

  .walk-row {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .walk-row a {
    font-size: var(--size-base);
  }

  .walk-meta {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-meta);
  }

  .empty {
    font-size: var(--size-sm);
    color: var(--color-meta);
  }
</style>
