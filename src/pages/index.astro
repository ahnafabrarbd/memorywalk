---
import List from "../layouts/List.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../site.config";

const walks = await getCollection("walks");
const recent = walks
  .sort((a, b) => b.data.started_at.getTime() - a.data.started_at.getTime())
  .slice(0, 8);
---

<List title={siteConfig.name}>
  <div class="landing">
    <h1 class="landing-title">{siteConfig.name}</h1>
    <p class="landing-tagline">{siteConfig.epigraph}</p>

    <a href="/write/new" class="landing-cta">+ new walk</a>

    <div class="recent">
      <h2 class="section-label">recent walks</h2>
      {recent.length > 0 ? (
        <ul class="walk-list">
          {recent.map((w) => {
            const parts = w.id.split("/");
            const slug = parts[1];
            return (
              <li class="walk-row">
                <a href={`/walk/${slug}`} class="walk-title">{w.data.title}</a>
                <span class="walk-meta">
                  {w.data.started_at.toISOString().slice(0, 10)}
                  {w.data.tags.length > 0 && (
                    <span class="walk-tags">
                      {w.data.tags.map((t) => `#${t}`).join(" ")}
                    </span>
                  )}
                </span>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="empty">no walks yet</p>
      )}
    </div>
  </div>
</List>

<style>
  .landing {
    padding-top: clamp(4rem, 15vh, 10rem);
  }

  .landing-title {
    font-family: var(--font-display);
    font-size: var(--size-title-landing);
    font-weight: 700;
    line-height: 0.95;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .landing-tagline {
    font-size: var(--size-body);
    color: var(--color-dim);
    max-width: 50ch;
    margin-bottom: 2rem;
  }

  .landing-cta {
    display: inline-block;
    font-family: var(--font-display);
    font-size: var(--size-index-title);
    font-weight: 700;
    color: var(--color-accent-green);
    border: 1px solid var(--color-accent-green);
    padding: 0.6rem 1.5rem;
    margin-bottom: clamp(3rem, 8vh, 6rem);
    transition: all 150ms;
  }

  .landing-cta:hover {
    color: #000;
    background: var(--color-accent-green);
    text-decoration: none;
  }

  .section-label {
    font-family: var(--font-display);
    font-size: var(--size-label);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-green);
    margin-bottom: 1rem;
  }

  .walk-list {
    list-style: none;
  }

  .walk-row {
    padding: clamp(0.75rem, 1.5vh, 1.25rem) 0;
    border-bottom: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .walk-row:first-child {
    border-top: 1px solid var(--color-rule);
  }

  .walk-title {
    font-family: var(--font-display);
    font-size: var(--size-index-title);
    font-weight: 600;
    color: var(--color-text);
  }

  .walk-title:hover {
    color: var(--color-accent-red);
  }

  .walk-meta {
    font-family: var(--font-display);
    font-size: var(--size-label);
    font-weight: 500;
    color: var(--color-dim);
  }

  .walk-tags {
    color: var(--color-accent-blue);
    margin-left: 0.5rem;
  }

  .empty {
    font-size: var(--size-body);
    color: var(--color-dim);
  }

  @media (max-width: 480px) {
    .landing {
      padding-top: 3rem;
    }
  }
</style>
