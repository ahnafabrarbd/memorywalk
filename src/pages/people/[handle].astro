---
import List from "../../layouts/List.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const people = await getCollection("people");
  return people.map((person) => ({
    params: { handle: person.data.handle },
    props: { person },
  }));
}

const { person } = Astro.props;
const { Content } = await render(person);

const walks = await getCollection("walks");
const authorWalks = walks
  .filter((w) => w.data.author === person.data.handle)
  .sort((a, b) => b.data.started_at.getTime() - a.data.started_at.getTime());
---

<List title={person.data.handle}>
  <div class="profile">
    <h1 class="profile-handle">{person.data.handle}</h1>
    <div class="profile-bio">
      <Content />
    </div>
    <a class="profile-link" href={person.data.link}>{person.data.link}</a>

    <h2 class="section-heading">walks</h2>
    {authorWalks.length > 0 ? (
      <ul class="walk-list">
        {authorWalks.map((w) => {
          const parts = w.id.split("/");
          return (
            <li class="walk-row">
              <a href={`/walk/${parts[0]}/${parts[1]}`}>{w.data.title}</a>
              <span class="walk-meta">
                {w.data.started_at.toISOString().slice(0, 10)}
              </span>
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="empty">no walks yet</p>
    )}
  </div>
</List>

<style>
  .profile {
    padding-top: 2rem;
  }

  .profile-handle {
    font-size: var(--size-lg);
    font-weight: normal;
    margin-bottom: 0.5rem;
  }

  .profile-bio {
    font-size: var(--size-base);
    color: var(--color-meta);
    max-width: var(--measure);
    margin-bottom: 0.5rem;
  }

  .profile-link {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-meta);
    display: block;
    margin-bottom: 2rem;
  }

  .section-heading {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    font-weight: normal;
    color: var(--color-meta);
    margin-bottom: 1rem;
  }

  .walk-list {
    list-style: none;
  }

  .walk-row {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .walk-row a {
    font-size: var(--size-base);
  }

  .walk-meta {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-meta);
  }

  .empty {
    font-size: var(--size-sm);
    color: var(--color-meta);
  }
</style>
