---
import List from "../layouts/List.astro";
import { siteConfig } from "../../site.config";
---

<List title="colophon">
  <div class="colophon-page">
    <h1 class="page-heading">colophon</h1>
    <div class="colophon-body">
      <p>{siteConfig.name} is built with astro. maps use leaflet with openstreetmap tiles. images are processed through a custom 0.3MP sensor emulation pipeline.</p>
      <p>references: are.na (structure), adaweb.com/project/aitken (reader), 0.3MP Camera by dwsh (image processing).</p>
      <p>code: MIT license. content: CC BY-NC-SA 4.0.</p>
    </div>
  </div>
</List>

<style>
  .colophon-page {
    padding-top: 2rem;
  }

  .page-heading {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    font-weight: normal;
    color: var(--color-meta);
    margin-bottom: 1.5rem;
  }

  .colophon-body {
    max-width: var(--measure);
    font-size: var(--size-base);
    color: var(--color-meta);
  }

  .colophon-body p {
    margin-bottom: 1rem;
  }
</style>
