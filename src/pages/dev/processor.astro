---
import List from "../../layouts/List.astro";

// Dev-only: could gate this behind import.meta.env.DEV if needed
---

<List title="0.3MP processor">
  <div class="harness">
    <h1 class="page-heading">0.3MP processor</h1>
    <p class="note">drag an image or click to select. browser-only, nothing is uploaded.</p>

    <div class="drop-zone" id="dropZone">
      <span class="drop-text">drop image here</span>
      <input type="file" accept="image/*" id="fileInput" />
    </div>

    <div class="comparison" id="comparison" style="display:none;">
      <div class="panel">
        <h2 class="panel-label">original</h2>
        <canvas id="originalCanvas"></canvas>
        <p class="panel-meta" id="originalMeta"></p>
      </div>
      <div class="panel">
        <h2 class="panel-label">processed</h2>
        <canvas id="processedCanvas"></canvas>
        <p class="panel-meta" id="processedMeta"></p>
      </div>
    </div>

    <div class="exif-data" id="exifData" style="display:none;">
      <h2 class="panel-label">exif</h2>
      <pre id="exifPre"></pre>
    </div>

    <div class="processing" id="processing" style="display:none;">
      <span>processing...</span>
    </div>
  </div>
</List>

<style>
  .harness {
    padding-top: 2rem;
  }

  .page-heading {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    font-weight: normal;
    color: var(--color-meta);
    margin-bottom: 0.25rem;
  }

  .note {
    font-size: var(--size-sm);
    color: var(--color-meta);
    margin-bottom: 1.5rem;
  }

  .drop-zone {
    border: 1px dashed var(--color-rule);
    padding: 3rem;
    text-align: center;
    cursor: pointer;
    position: relative;
    margin-bottom: 2rem;
  }

  .drop-zone.dragover {
    border-color: var(--color-text);
  }

  .drop-text {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-meta);
  }

  .drop-zone input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }

  .comparison {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 800px) {
    .comparison {
      grid-template-columns: 1fr;
    }
  }

  .panel canvas {
    width: 100%;
    height: auto;
    display: block;
  }

  .panel-label {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    font-weight: normal;
    color: var(--color-meta);
    margin-bottom: 0.5rem;
  }

  .panel-meta {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-meta);
    margin-top: 0.5rem;
  }

  .exif-data {
    margin-bottom: 2rem;
  }

  .exif-data pre {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-meta);
    white-space: pre-wrap;
    word-break: break-all;
  }

  .processing {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-meta);
  }
</style>

<script>
  import { processImage } from "../../lib/processor/index";
  import exifr from "exifr";

  const dropZone = document.getElementById("dropZone")!;
  const fileInput = document.getElementById("fileInput") as HTMLInputElement;
  const comparison = document.getElementById("comparison")!;
  const originalCanvas = document.getElementById("originalCanvas") as HTMLCanvasElement;
  const processedCanvas = document.getElementById("processedCanvas") as HTMLCanvasElement;
  const originalMeta = document.getElementById("originalMeta")!;
  const processedMeta = document.getElementById("processedMeta")!;
  const exifData = document.getElementById("exifData")!;
  const exifPre = document.getElementById("exifPre")!;
  const processing = document.getElementById("processing")!;

  dropZone.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropZone.classList.add("dragover");
  });

  dropZone.addEventListener("dragleave", () => {
    dropZone.classList.remove("dragover");
  });

  dropZone.addEventListener("drop", (e) => {
    e.preventDefault();
    dropZone.classList.remove("dragover");
    const file = e.dataTransfer?.files[0];
    if (file) handleFile(file);
  });

  fileInput.addEventListener("change", () => {
    const file = fileInput.files?.[0];
    if (file) handleFile(file);
  });

  async function handleFile(file: File) {
    processing.style.display = "block";
    comparison.style.display = "none";
    exifData.style.display = "none";

    try {
      // Extract EXIF
      const exif = await exifr.parse(file, {
        pick: ["DateTimeOriginal", "GPSLatitude", "GPSLongitude", "Make", "Model", "ImageWidth", "ImageHeight"],
      }).catch(() => null);

      if (exif) {
        const parts: string[] = [];
        if (exif.DateTimeOriginal) parts.push(`captured: ${exif.DateTimeOriginal}`);
        if (exif.GPSLatitude != null && exif.GPSLongitude != null) {
          parts.push(`coords: [${exif.latitude?.toFixed(6)}, ${exif.longitude?.toFixed(6)}]`);
        }
        if (exif.Make) parts.push(`camera: ${exif.Make} ${exif.Model || ""}`);
        if (parts.length > 0) {
          exifPre.textContent = parts.join("\n");
          exifData.style.display = "block";
        }
      }

      // Show original
      const origImg = new Image();
      await new Promise<void>((resolve) => {
        origImg.onload = () => resolve();
        origImg.src = URL.createObjectURL(file);
      });

      originalCanvas.width = origImg.naturalWidth;
      originalCanvas.height = origImg.naturalHeight;
      originalCanvas.getContext("2d")!.drawImage(origImg, 0, 0);
      originalMeta.textContent = `${origImg.naturalWidth}x${origImg.naturalHeight} · ${(file.size / 1024).toFixed(0)}kb`;
      URL.revokeObjectURL(origImg.src);

      // Process
      const blob = await processImage(file);

      // Show processed
      const procImg = new Image();
      await new Promise<void>((resolve) => {
        procImg.onload = () => resolve();
        procImg.src = URL.createObjectURL(blob);
      });

      processedCanvas.width = procImg.naturalWidth;
      processedCanvas.height = procImg.naturalHeight;
      processedCanvas.getContext("2d")!.drawImage(procImg, 0, 0);
      processedMeta.textContent = `${procImg.naturalWidth}x${procImg.naturalHeight} · ${(blob.size / 1024).toFixed(0)}kb`;
      URL.revokeObjectURL(procImg.src);

      comparison.style.display = "grid";
    } catch (err) {
      console.error("Processing failed:", err);
      exifPre.textContent = `error: ${err}`;
      exifData.style.display = "block";
    } finally {
      processing.style.display = "none";
    }
  }
</script>
